<%
  columns = [
    {
      title: "Name",
      class: "name-col font-weight-bold",
      html: ->(country) { content_tag(:span, country.name, class: "name-text") }
    },
    {
      title: "Description",
      class: "description-col",
      value: ->(country) { country.description.presence || "-" }
    },
    {
      title: "Remarks",
      class: "remarks-col",
      value: ->(country) { country.remarks.presence || "-" }
    },
    {
      title: "Actions",
      class: "actions-col text-right",
      html: lambda { |country|
        resource_grid_actions(
          country,
          view_path: country_path(country),
          edit_path: edit_country_path(country),
          delete_path: country_path(country)
        )
      }
    }
  ]
%>

<%= render "layouts/resource_index_grid",
           title: "Countries",
           new_label: "New Country",
           new_path: new_country_path,
           collection: @countries,
           columns: columns,
           grid_id: "countries-grid" %>
