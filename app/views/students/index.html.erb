<div class="card page-card">
  <div class="card-header resource-card-header py-3 px-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
      <div>
        <h1 class="section-title h3 mb-1"><%= @search_mode ? "Search Students" : "Students" %></h1>
        <p class="text-muted mb-0">Review student profiles, guardians, enrolled classes, and current teachers.</p>
      </div>
      <%= link_to "New Student", new_student_path, class: "btn resource-grid__create-button text-white" %>
    </div>
  </div>

  <div class="card-body pt-4">
    <%= form_with url: (@search_mode ? search_students_path : students_path), method: :get, local: true, class: "admin-search-form" do %>
      <div class="row g-3 align-items-end">
        <div class="col-md-8">
          <%= label_tag :q, "Search by student number, name, or email", class: "font-weight-bold" %>
          <%= text_field_tag :q, @search_query, class: "form-control", placeholder: "Search students" %>
        </div>
        <div class="col-md-4 d-flex gap-2">
          <%= submit_tag "Search", class: "btn btn-outline-brand flex-grow-1" %>
          <%= link_to "Reset", students_path, class: "btn btn-outline-secondary flex-grow-1" %>
        </div>
      </div>
    <% end %>

    <div class="resource-grid-shell mt-4">
      <table class="table resource-kendo-grid mb-0">
        <thead>
          <tr>
            <th>Student No.</th>
            <th>Name</th>
            <th>Guardians</th>
            <th>Current Classes</th>
            <th>Status</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @students.each do |student| %>
            <tr>
              <td class="font-weight-bold"><%= student.student_number %></td>
              <td>
                <div class="font-weight-bold"><%= student.full_name %></div>
                <div class="text-muted small"><%= student.email.presence || "-" %></div>
              </td>
              <td><%= student.guardians.limit(2).map(&:full_name).presence&.join(", ") || "-" %></td>
              <td><%= student.academic_classes.limit(2).map(&:display_name).presence&.join(", ") || "-" %></td>
              <td><span class="badge badge-light text-uppercase"><%= student.status %></span></td>
              <td class="text-right"><%= resource_grid_actions(student, view_path: student_path(student), edit_path: edit_student_path(student), delete_path: student_path(student)) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="pagination-wrap d-flex justify-content-center mt-4">
      <%= paginate @students, window: 2, outer_window: 0, left: 0, right: 0 %>
    </div>
  </div>
</div>
