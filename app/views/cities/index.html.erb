<%
  columns = [
    {
      title: "Name",
      class: "name-col font-weight-bold",
      html: ->(city) { content_tag(:span, city.name, class: "name-text") }
    },
    {
      title: "Province",
      class: "name-col",
      value: ->(city) { city.province&.name || "-" }
    },
    {
      title: "Description",
      class: "description-col",
      value: ->(city) { city.description.presence || "-" }
    },
    {
      title: "Remarks",
      class: "remarks-col",
      value: ->(city) { city.remarks.presence || "-" }
    },
    {
      title: "Type",
      class: "type-col",
      html: lambda { |city|
        if city.is_municipality
          content_tag(:span, "Municipality", class: "badge badge-municipality")
        else
          content_tag(:span, "City", class: "badge badge-city")
        end
      }
    },
    {
      title: "Actions",
      class: "actions-col text-right",
      html: lambda { |city|
        resource_grid_actions(
          city,
          view_path: city_path(city),
          edit_path: edit_city_path(city),
          delete_path: city_path(city)
        )
      }
    }
  ]
%>

<%= render "layouts/resource_index_grid",
           title: "Cities",
           new_label: "New City",
           new_path: new_city_path,
           collection: @cities,
           columns: columns,
           grid_id: "cities-grid" %>
