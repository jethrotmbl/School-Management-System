<%= form_with(model: barangay, local: true) do |form| %>
  <% if barangay.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(barangay.errors.count, "error") %> prohibited this barangay from being saved:</strong>
      <ul class="mb-0 mt-2">
        <% barangay.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :name, class: "font-weight-bold" %>
    <%= form.text_field :name, class: "form-control", placeholder: "Enter barangay name" %>
  </div>

  <div class="form-group">
    <%= form.label :description, class: "font-weight-bold" %>
    <%= form.text_area :description, rows: 4, class: "form-control", placeholder: "Short description" %>
  </div>

  <div class="form-group">
    <%= form.label :remarks, class: "font-weight-bold" %>
    <%= form.text_area :remarks, rows: 3, class: "form-control", placeholder: "Additional remarks" %>
  </div>

  <div class="d-flex justify-content-between mt-4">
    <%= link_to 'Back', barangays_path, class: 'btn btn-outline-secondary' %>
    <%= form.submit 'Create Barangay', class: 'btn text-white', style: 'background-color: #0F0E47; border-color: #363636;' %>
  </div>
<% end %>
