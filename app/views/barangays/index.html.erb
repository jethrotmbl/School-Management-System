<%
  columns = [
    {
      title: "Name",
      class: "name-col font-weight-bold",
      html: ->(barangay) { content_tag(:span, barangay.name, class: "name-text") }
    },
    {
      title: "Location",
      class: "name-col",
      value: ->(barangay) { barangay.city&.name || "-" }
    },
    {
      title: "Description",
      class: "description-col",
      value: ->(barangay) { barangay.description.presence || "-" }
    },
    {
      title: "Remarks",
      class: "remarks-col",
      value: ->(barangay) { barangay.remarks.presence || "-" }
    },
    {
      title: "Actions",
      class: "actions-col text-right",
      html: lambda { |barangay|
        resource_grid_actions(
          barangay,
          view_path: barangay_path(barangay),
          edit_path: edit_barangay_path(barangay),
          delete_path: barangay_path(barangay)
        )
      }
    }
  ]
%>

<%= render "layouts/resource_index_grid",
           title: "Barangays",
           new_label: "New Barangay",
           new_path: new_barangay_path,
           collection: @barangays,
           columns: columns,
           grid_id: "barangays-grid" %>
