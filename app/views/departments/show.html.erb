<div class="card page-card"><div class="card-body"><div class="d-flex justify-content-between align-items-center mb-4"><h1 class="section-title h3 mb-0"><%= @department.name %></h1><div><%= link_to "Edit", edit_department_path(@department), class: "btn btn-outline-brand" %> <%= link_to "Back", departments_path, class: "btn btn-outline-secondary" %></div></div><div class="row"><div class="col-md-4 mb-3"><div class="muted-label">Code</div><div><%= @department.code.presence || "-" %></div></div><div class="col-md-8 mb-3"><div class="muted-label">Description</div><div><%= @department.description.presence || "-" %></div></div></div><h2 class="section-title h5 mb-3">Teachers</h2><% if @teachers.any? %><% @teachers.each do |teacher| %><div class="admin-related-item"><div class="font-weight-bold"><%= link_to teacher.full_name, teacher_path(teacher) %></div><div class="text-muted small"><%= teacher.employee_number %></div></div><% end %><% else %><div class="text-muted">No teachers assigned.</div><% end %></div></div>
