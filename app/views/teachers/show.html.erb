<div class="card page-card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
      <div><div class="muted-label">Teacher Profile</div><h1 class="section-title h3 mb-0"><%= @teacher.full_name %></h1><div class="text-muted mt-1"><%= @teacher.employee_number %></div></div>
      <div class="d-flex gap-2"><%= link_to "Edit", edit_teacher_path(@teacher), class: "btn btn-outline-brand" %><%= link_to "Back", teachers_path, class: "btn btn-outline-secondary" %></div>
    </div>
    <div class="row">
      <div class="col-md-3 mb-3"><div class="muted-label">Department</div><div><%= @teacher.department&.name || "-" %></div></div>
      <div class="col-md-3 mb-3"><div class="muted-label">Status</div><div><%= @teacher.status.titleize %></div></div>
      <div class="col-md-3 mb-3"><div class="muted-label">Hire Date</div><div><%= @teacher.hire_date&.strftime("%b %d, %Y") || "-" %></div></div>
      <div class="col-md-3 mb-3"><div class="muted-label">Citizenship</div><div><%= @teacher.citizenship&.name || "-" %></div></div>
      <div class="col-md-6 mb-3"><div class="muted-label">Email</div><div><%= @teacher.email.presence || "-" %></div></div>
      <div class="col-md-6 mb-3"><div class="muted-label">Phone</div><div><%= @teacher.phone.presence || "-" %></div></div>
      <div class="col-md-12 mb-3"><div class="muted-label">Specialization</div><div><%= @teacher.specialization.presence || "-" %></div></div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-6 mb-4"><div class="card page-card h-100"><div class="card-body"><h2 class="section-title h5 mb-3">Handled Classes</h2><% if @teacher_classes.any? %><% @teacher_classes.each do |academic_class| %><div class="admin-related-item"><div class="font-weight-bold"><%= link_to academic_class.display_name, academic_class_path(academic_class) %></div><div class="text-muted small"><%= academic_class.school_year.name %></div></div><% end %><% else %><div class="text-muted">No classes assigned.</div><% end %></div></div></div>
  <div class="col-lg-6 mb-4"><div class="card page-card h-100"><div class="card-body"><h2 class="section-title h5 mb-3">Students</h2><% if @teacher_students.any? %><% @teacher_students.each do |student| %><div class="admin-related-item"><div class="font-weight-bold"><%= link_to student.full_name, student_path(student) %></div><div class="text-muted small"><%= student.student_number %></div></div><% end %><% else %><div class="text-muted">No students linked yet.</div><% end %></div></div></div>
</div>
