<%
  columns = [
    {
      title: "Name",
      class: "name-col font-weight-bold",
      html: ->(region) { content_tag(:span, region.name, class: "name-text") }
    },
    {
      title: "Country",
      class: "name-col",
      value: ->(region) { region.country&.name || "-" }
    },
    {
      title: "Description",
      class: "description-col",
      value: ->(region) { region.description.presence || "-" }
    },
    {
      title: "Remarks",
      class: "remarks-col",
      value: ->(region) { region.remarks.presence || "-" }
    },
    {
      title: "Actions",
      class: "actions-col text-right",
      html: lambda { |region|
        resource_grid_actions(
          region,
          view_path: region_path(region),
          edit_path: edit_region_path(region),
          delete_path: region_path(region)
        )
      }
    }
  ]
%>

<%= render "layouts/resource_index_grid",
           title: "Regions",
           new_label: "New Region",
           new_path: new_region_path,
           collection: @regions,
           columns: columns,
           grid_id: "regions-grid" %>
