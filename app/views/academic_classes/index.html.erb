<div class="card page-card">
  <div class="card-header resource-card-header py-3 px-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
      <div><h1 class="section-title h3 mb-1">Classes</h1><p class="text-muted mb-0">See offered classes, assigned teachers, field of study, and student enrollment counts.</p></div>
      <%= link_to "New Class", new_academic_class_path, class: "btn resource-grid__create-button text-white" %>
    </div>
  </div>
  <div class="card-body pt-4">
    <%= form_with url: academic_classes_path, method: :get, local: true, class: "admin-search-form" do %>
      <div class="row g-3 align-items-end">
        <div class="col-md-8"><%= text_field_tag :q, @search_query, class: "form-control", placeholder: "Search classes" %></div>
        <div class="col-md-4 d-flex gap-2"><%= submit_tag "Search", class: "btn btn-outline-brand flex-grow-1" %><%= link_to "Reset", academic_classes_path, class: "btn btn-outline-secondary flex-grow-1" %></div>
      </div>
    <% end %>
    <div class="resource-grid-shell mt-4">
      <table class="table resource-kendo-grid mb-0">
        <thead><tr><th>Class</th><th>Teacher</th><th>Field of Study</th><th>School Year</th><th>Students</th><th class="text-right">Actions</th></tr></thead>
        <tbody>
          <% @academic_classes.each do |academic_class| %>
            <tr>
              <td><div class="font-weight-bold"><%= academic_class.display_name %></div><div class="text-muted small"><%= pluralize(academic_class.units, "unit") %></div></td>
              <td><%= academic_class.teacher&.full_name || "-" %></td>
              <td><%= academic_class.field_of_study&.name || "-" %></td>
              <td><%= academic_class.school_year.name %></td>
              <td><%= academic_class.students.count %></td>
              <td class="text-right"><%= resource_grid_actions(academic_class, view_path: academic_class_path(academic_class), edit_path: edit_academic_class_path(academic_class), delete_path: academic_class_path(academic_class)) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="pagination-wrap d-flex justify-content-center mt-4"><%= paginate @academic_classes, window: 2, outer_window: 0, left: 0, right: 0 %></div>
  </div>
</div>
