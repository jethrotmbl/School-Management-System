<div class="card page-card mb-4"><div class="card-body"><div class="d-flex justify-content-between align-items-center mb-4 flex-wrap"><div><div class="muted-label">Class</div><h1 class="section-title h3 mb-0"><%= @academic_class.display_name %></h1></div><div><%= link_to "Edit", edit_academic_class_path(@academic_class), class: "btn btn-outline-brand" %> <%= link_to "Back", academic_classes_path, class: "btn btn-outline-secondary" %></div></div><div class="row"><div class="col-md-3 mb-3"><div class="muted-label">Teacher</div><div><%= @academic_class.teacher&.full_name || "-" %></div></div><div class="col-md-3 mb-3"><div class="muted-label">School Year</div><div><%= @academic_class.school_year.name %></div></div><div class="col-md-3 mb-3"><div class="muted-label">Track</div><div><%= [@academic_class.degree&.name, @academic_class.field_of_study&.name].compact.join(" / ").presence || "-" %></div></div><div class="col-md-3 mb-3"><div class="muted-label">Status</div><div><%= @academic_class.status.titleize %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Schedule</div><div><%= @academic_class.schedule.presence || "-" %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Room</div><div><%= @academic_class.room.presence || "-" %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Units</div><div><%= @academic_class.units %></div></div></div><div class="mb-4"><div class="muted-label">Description</div><div><%= @academic_class.description.presence || "-" %></div></div><h2 class="section-title h5 mb-3">Enrolled Students</h2><% if @enrollments.any? %><div class="table-responsive"><table class="table mb-0"><thead><tr><th>Student</th><th>Status</th><th>Enrolled On</th></tr></thead><tbody><% @enrollments.each do |enrollment| %><tr><td><%= link_to enrollment.student.full_name, student_path(enrollment.student) %></td><td><%= enrollment.status.titleize %></td><td><%= enrollment.enrolled_on&.strftime("%b %d, %Y") || "-" %></td></tr><% end %></tbody></table></div><% else %><div class="text-muted">No students enrolled yet.</div><% end %></div></div>
