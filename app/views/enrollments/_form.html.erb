<%= form_with(model: enrollment, local: true) do |form| %>
  <% if enrollment.errors.any? %><div class="alert alert-danger"><%= enrollment.errors.full_messages.to_sentence %></div><% end %>
  <div class="form-group"><%= form.label :student_id, "Student", class: "font-weight-bold" %><%= form.collection_select :student_id, @students, :id, :full_name, { include_blank: "Select student" }, class: "form-control" %></div>
  <div class="form-group"><%= form.label :academic_class_id, "Class", class: "font-weight-bold" %><%= form.collection_select :academic_class_id, @academic_classes, :id, :display_name, { include_blank: "Select class" }, class: "form-control" %></div>
  <div class="row"><div class="col-md-6 form-group"><%= form.label :school_year_id, "School Year", class: "font-weight-bold" %><%= form.collection_select :school_year_id, @school_years, :id, :name, { include_blank: "Select school year" }, class: "form-control" %></div><div class="col-md-6 form-group"><%= form.label :enrollment_period_id, "Enrollment Period", class: "font-weight-bold" %><%= form.collection_select :enrollment_period_id, @enrollment_periods, :id, :name, { include_blank: "Select enrollment period" }, class: "form-control" %></div></div>
  <div class="row"><div class="col-md-4 form-group"><%= form.label :status, class: "font-weight-bold" %><%= form.select :status, Enrollment::STATUSES.map { |status| [status.titleize, status] }, {}, class: "form-control" %></div><div class="col-md-4 form-group"><%= form.label :enrolled_on, class: "font-weight-bold" %><%= form.date_field :enrolled_on, class: "form-control" %></div><div class="col-md-4 form-group"><%= form.label :final_grade, class: "font-weight-bold" %><%= form.number_field :final_grade, step: 0.01, class: "form-control" %></div></div>
  <div class="form-group"><%= form.label :remarks, class: "font-weight-bold" %><%= form.text_area :remarks, rows: 4, class: "form-control" %></div>
  <div class="d-flex justify-content-between mt-4"><%= link_to "Back", enrollments_path, class: "btn btn-outline-secondary" %><%= form.submit class: "btn text-white", style: "background-color: #0F0E47; border-color: #0F0E47;" %></div>
<% end %>
