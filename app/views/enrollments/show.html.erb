<div class="card page-card"><div class="card-body"><div class="d-flex justify-content-between align-items-center mb-4"><h1 class="section-title h3 mb-0">Enrollment</h1><div><%= link_to "Edit", edit_enrollment_path(@enrollment), class: "btn btn-outline-brand" %> <%= link_to "Back", enrollments_path, class: "btn btn-outline-secondary" %></div></div><div class="row"><div class="col-md-6 mb-3"><div class="muted-label">Student</div><div><%= link_to @enrollment.student.full_name, student_path(@enrollment.student) %></div></div><div class="col-md-6 mb-3"><div class="muted-label">Class</div><div><%= link_to @enrollment.academic_class.display_name, academic_class_path(@enrollment.academic_class) %></div></div><div class="col-md-4 mb-3"><div class="muted-label">School Year</div><div><%= @enrollment.school_year.name %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Enrollment Period</div><div><%= @enrollment.enrollment_period&.name || "-" %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Status</div><div><%= @enrollment.status.titleize %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Enrolled On</div><div><%= @enrollment.enrolled_on&.strftime("%b %d, %Y") || "-" %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Final Grade</div><div><%= @enrollment.final_grade.presence || "-" %></div></div><div class="col-md-12 mb-3"><div class="muted-label">Remarks</div><div><%= @enrollment.remarks.presence || "-" %></div></div></div></div></div>
