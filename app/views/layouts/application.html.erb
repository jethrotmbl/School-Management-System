<!DOCTYPE html>
<html>
  <head>
    <title>School Management System</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= stylesheet_link_tag    'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body class="app-body">
    <main class="app-page-main">
      <section class="home-dashboard-shell">
        <header
          id="home-dashboard-toolbar"
          class="home-dashboard-toolbar"
          data-navigation-items="<%= json_escape(drawer_navigation_items.to_json) %>"
          data-current-key="<%= current_drawer_key %>"
          data-current-child-key="<%= current_drawer_child_key %>">
          <div class="home-dashboard-toolbar__inner">
            <button
              id="home-dashboard-menu-button"
              type="button"
              class="home-dashboard-toolbar__toggle"
              aria-label="Open navigation">
              <span class="home-dashboard-toolbar__toggle-line"></span>
              <span class="home-dashboard-toolbar__toggle-line"></span>
              <span class="home-dashboard-toolbar__toggle-line"></span>
            </button>

            <div class="home-dashboard-toolbar__title-wrap">
              <span class="home-dashboard-toolbar__title">School Management System</span>
            </div>
          </div>
        </header>

        <div class="home-dashboard-layout">
          <div class="home-dashboard-layout__rail">
            <div id="home-dashboard-drawer" class="home-dashboard-drawer"></div>
            <div id="home-dashboard-subdrawer" class="home-dashboard-subdrawer" aria-hidden="true"></div>
          </div>

          <div id="home-dashboard-content" class="home-dashboard-content">
            <% flash.each do |type, message| %>
              <% next if message.blank? %>
              <% alert_class = type.to_s == "notice" ? "alert-success" : "alert-danger" %>
              <div class="alert <%= alert_class %> alert-dismissible fade show" role="alert">
                <%= message %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% end %>

            <%= yield %>
          </div>
        </div>
      </section>
    </main>

    <footer class="app-footer mt-auto">
      <div class="container app-footer__content">
        <nav class="app-footer__nav" aria-label="Footer">
          <%= link_to "About", "#", class: "app-footer__link" %>
          <%= link_to "Contact", "#", class: "app-footer__link" %>
          <%= link_to "Services", "#", class: "app-footer__link" %>
          <%= link_to "Support", "#", class: "app-footer__link" %>
          <%= link_to "Privacy", "#", class: "app-footer__link" %>
          <%= link_to "Terms", "#", class: "app-footer__link" %>
        </nav>
        <div class="app-footer__brand">
          <span class="app-footer__brand-icon" aria-hidden="true">
            <%= kendo_icon("home", classes: "app-footer__brand-icon-symbol") %>
          </span>
          <p class="app-footer__title">School Management System</p>
        </div>
        <p class="app-footer__text">All Rights Reserved 2026</p>
      </div>
    </footer>
  </body>
</html>
