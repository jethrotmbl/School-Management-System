<div class="card page-card">
  <div class="card-header resource-card-header py-3 px-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
      <div>
        <h1 class="section-title h3 mb-0"><%= title %></h1>
      </div>
      <%= link_to new_label, new_path, class: "btn resource-grid__create-button text-white" %>
    </div>
  </div>

  <div class="card-body pt-4">
    <div class="resource-grid-shell">
      <table id="<%= grid_id %>" class="table resource-kendo-grid js-resource-grid mb-0">
        <thead>
          <tr>
            <% columns.each do |column| %>
              <th class="<%= column[:class] %>"><%= column[:title] %></th>
            <% end %>
          </tr>
        </thead>

        <tbody>
          <% collection.each do |record| %>
            <tr>
              <% columns.each do |column| %>
                <td class="<%= column[:class] %>">
                  <%= resource_grid_render(record, column[:html] || column[:value]) %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="pagination-wrap d-flex justify-content-center mt-4">
      <%= paginate collection, window: 2, outer_window: 0, left: 0, right: 0 %>
    </div>
  </div>
</div>
