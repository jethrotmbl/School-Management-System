<%
  columns = [
    { title: "School Year", class: "font-weight-bold", html: ->(school_year) { link_to(school_year.name, school_year_path(school_year), class: "text-reset", style: "text-decoration: none;") } },
    { title: "Date Range", class: "", value: ->(school_year) { school_year.date_range } },
    { title: "Status", class: "", value: ->(school_year) { school_year.status.titleize } },
    { title: "Actions", class: "text-right", html: lambda { |school_year|
      action_links = [
        link_to("View", school_year_path(school_year), class: "btn btn-sm btn-outline-secondary"),
        link_to("Edit", edit_school_year_path(school_year), class: "btn btn-sm btn-outline-brand")
      ]

      action_links << link_to("Open", open_school_year_path(school_year), method: :patch, class: "btn btn-sm btn-success") if school_year.status == "archived"

      action_links << link_to("Delete", school_year_path(school_year), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger")

      safe_join(action_links)
    } }
  ]
%>
<%= render "layouts/resource_index_grid", title: "School Years", new_label: "New School Year", new_path: new_school_year_path, collection: @school_years, columns: columns, grid_id: "school-years-grid" %>
