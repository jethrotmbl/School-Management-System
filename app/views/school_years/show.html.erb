<div class="card page-card mb-4"><div class="card-body"><div class="d-flex justify-content-between align-items-center mb-4 flex-wrap"><div><div class="muted-label">School Year</div><h1 class="section-title h3 mb-0"><%= @school_year.name %></h1></div><div><%= link_to "Edit", edit_school_year_path(@school_year), class: "btn btn-outline-brand" %> <%= link_to "Back", school_years_path, class: "btn btn-outline-secondary" %></div></div><div class="row"><div class="col-md-4 mb-3"><div class="muted-label">Date Range</div><div><%= @school_year.date_range %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Status</div><div><%= @school_year.status.titleize %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Opened At</div><div><%= @school_year.opened_at&.strftime("%b %d, %Y %I:%M %p") || "-" %></div></div></div><div class="mb-4"><div class="muted-label">Description</div><div><%= @school_year.description.presence || "-" %></div></div><div class="row"><div class="col-lg-4 mb-4"><h2 class="section-title h5 mb-3">Enrollment Periods</h2><% if @enrollment_periods.any? %><% @enrollment_periods.each do |period| %><div class="admin-related-item"><div class="font-weight-bold"><%= link_to period.name, enrollment_period_path(period) %></div><div class="text-muted small"><%= period.status.titleize %></div></div><% end %><% else %><div class="text-muted">No periods yet.</div><% end %></div><div class="col-lg-4 mb-4"><h2 class="section-title h5 mb-3">Classes</h2><% if @academic_classes.any? %><% @academic_classes.each do |academic_class| %><div class="admin-related-item"><div class="font-weight-bold"><%= link_to academic_class.display_name, academic_class_path(academic_class) %></div><div class="text-muted small"><%= academic_class.teacher&.full_name || "-" %></div></div><% end %><% else %><div class="text-muted">No classes yet.</div><% end %></div><div class="col-lg-4 mb-4"><h2 class="section-title h5 mb-3">Recent Enrollments</h2><% if @enrollments.any? %><% @enrollments.each do |enrollment| %><div class="admin-related-item"><div class="font-weight-bold"><%= link_to enrollment.student.full_name, student_path(enrollment.student) %></div><div class="text-muted small"><%= enrollment.academic_class.display_name %></div></div><% end %><% else %><div class="text-muted">No enrollments yet.</div><% end %></div></div></div></div>
