<div class="card page-card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
      <div>
        <div class="muted-label">School Year</div>
        <h1 class="section-title h3 mb-0"><%= @school_year.name %></h1>
      </div>
      <div>
        <%= link_to "Edit", edit_school_year_path(@school_year), class: "btn btn-outline-brand" %>
        <%= link_to "Back", school_years_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>

    <div class="row">
      <div class="col-md-4 mb-3"><div class="muted-label">Date Range</div><div><%= @school_year.date_range %></div></div>
      <div class="col-md-4 mb-3"><div class="muted-label">Status</div><div><%= @school_year.status.titleize %></div></div>
      <div class="col-md-4 mb-3"><div class="muted-label">Opened At</div><div><%= @school_year.opened_at&.strftime("%b %d, %Y %I:%M %p") || "-" %></div></div>
    </div>

    <div class="mb-4">
      <div class="muted-label">Description</div>
      <div><%= @school_year.description.presence || "-" %></div>
    </div>

    <h2 class="section-title h5 mb-3">Term Timeline</h2>
    <% return_to_path = school_year_path(@school_year) %>
    <% if @enrollment_periods.any? %>
      <div class="resource-grid-shell mb-3">
        <table class="table resource-kendo-grid mb-0">
          <thead>
            <tr>
              <th>Start</th>
              <th>End</th>
              <th>Term</th>
              <th>Status</th>
              <th>Current</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @enrollment_periods.each do |period| %>
              <tr>
                <td><%= period.starts_on&.strftime("%b %d, %Y") || "-" %></td>
                <td><%= period.ends_on&.strftime("%b %d, %Y") || "-" %></td>
                <td class="font-weight-bold"><%= link_to period.name, enrollment_period_path(period, return_to: return_to_path), class: "text-reset", style: "text-decoration: none;" %></td>
                <td><%= period.status.titleize %></td>
                <td><%= period.status == "active" ? "Active" : "" %></td>
                <td class="text-right">
                  <div class="resource-grid-actions">
                    <%= link_to "View", enrollment_period_path(period, return_to: return_to_path), class: "btn btn-sm btn-outline-secondary" %>
                    <%= link_to "Edit", edit_enrollment_period_path(period, return_to: return_to_path), class: "btn btn-sm btn-outline-brand" %>
                    <%= link_to "Delete", enrollment_period_path(period), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" %>
                    <% if period.status != "active" %>
                      <%= link_to "Set Current", set_current_enrollment_period_path(period), method: :patch, class: "btn btn-sm btn-outline-brand" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <small class="text-muted">Open a term to view and manage its classes and recent enrollments.</small>
    <% else %>
      <div class="text-muted mb-4">No terms yet.</div>
    <% end %>
  </div>
</div>
