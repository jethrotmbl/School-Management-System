<div class="card page-card"><div class="card-body"><div class="d-flex justify-content-between align-items-center mb-4"><h1 class="section-title h3 mb-0"><%= @field_of_study.name %></h1><div><%= link_to "Edit", edit_field_of_study_path(@field_of_study), class: "btn btn-outline-brand" %> <%= link_to "Back", field_of_studies_path, class: "btn btn-outline-secondary" %></div></div><div class="row"><div class="col-md-4 mb-3"><div class="muted-label">Degree</div><div><%= @field_of_study.degree&.name || "-" %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Code</div><div><%= @field_of_study.code.presence || "-" %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Classes</div><div><%= @academic_classes.count %></div></div><div class="col-md-12 mb-3"><div class="muted-label">Description</div><div><%= @field_of_study.description.presence || "-" %></div></div></div><h2 class="section-title h5 mb-3">Classes</h2><% if @academic_classes.any? %><% @academic_classes.each do |academic_class| %><div class="admin-related-item"><div class="font-weight-bold"><%= link_to academic_class.display_name, academic_class_path(academic_class) %></div><div class="text-muted small"><%= academic_class.teacher&.full_name || "-" %></div></div><% end %><% else %><div class="text-muted">No classes linked yet.</div><% end %></div></div>
