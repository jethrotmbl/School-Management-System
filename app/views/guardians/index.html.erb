<div class="card page-card">
  <div class="card-header resource-card-header py-3 px-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
      <div>
        <h1 class="section-title h3 mb-1"><%= @search_mode ? "Search Guardians" : "Guardians" %></h1>
        <p class="text-muted mb-0">Track guardian contact records and the students connected to each household.</p>
      </div>
      <%= link_to "New Guardian", new_guardian_path, class: "btn resource-grid__create-button text-white" %>
    </div>
  </div>

  <div class="card-body pt-4">
    <%= form_with url: (@search_mode ? search_guardians_path : guardians_path), method: :get, local: true, class: "admin-search-form" do %>
      <div class="row g-3 align-items-end">
        <div class="col-md-8"><%= label_tag :q, "Search by guardian name, email, or phone", class: "font-weight-bold" %><%= text_field_tag :q, @search_query, class: "form-control", placeholder: "Search guardians" %></div>
        <div class="col-md-4 d-flex gap-2"><%= submit_tag "Search", class: "btn btn-outline-brand flex-grow-1" %><%= link_to "Reset", guardians_path, class: "btn btn-outline-secondary flex-grow-1" %></div>
      </div>
    <% end %>

    <div class="resource-grid-shell mt-4">
      <table class="table resource-kendo-grid mb-0">
        <thead><tr><th>Name</th><th>Relationship</th><th>Students</th><th>Contact</th><th class="text-right">Actions</th></tr></thead>
        <tbody>
          <% @guardians.each do |guardian| %>
            <tr>
              <td class="font-weight-bold"><%= guardian.full_name %></td>
              <td><%= guardian.relationship_to_student.presence || "-" %></td>
              <td><%= guardian.students.limit(2).map(&:full_name).presence&.join(", ") || "-" %></td>
              <td><%= guardian.phone.presence || guardian.email.presence || "-" %></td>
              <td class="text-right"><%= resource_grid_actions(guardian, view_path: guardian_path(guardian), edit_path: edit_guardian_path(guardian), delete_path: guardian_path(guardian)) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="pagination-wrap d-flex justify-content-center mt-4"><%= paginate @guardians, window: 2, outer_window: 0, left: 0, right: 0 %></div>
  </div>
</div>
