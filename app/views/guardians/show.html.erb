<div class="card page-card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
      <div><div class="muted-label">Guardian Profile</div><h1 class="section-title h3 mb-0"><%= @guardian.full_name %></h1></div>
      <div class="d-flex gap-2"><%= link_to "Edit", edit_guardian_path(@guardian), class: "btn btn-outline-brand" %><%= link_to "Back", guardians_path, class: "btn btn-outline-secondary" %></div>
    </div>
    <div class="row">
      <div class="col-md-4 mb-3"><div class="muted-label">Relationship</div><div><%= @guardian.relationship_to_student.presence || "-" %></div></div>
      <div class="col-md-4 mb-3"><div class="muted-label">Occupation</div><div><%= @guardian.occupation.presence || "-" %></div></div>
      <div class="col-md-4 mb-3"><div class="muted-label">Citizenship</div><div><%= @guardian.citizenship&.name || "-" %></div></div>
      <div class="col-md-6 mb-3"><div class="muted-label">Email</div><div><%= @guardian.email.presence || "-" %></div></div>
      <div class="col-md-6 mb-3"><div class="muted-label">Phone</div><div><%= @guardian.phone.presence || "-" %></div></div>
      <div class="col-md-12 mb-3"><div class="muted-label">Address</div><div><%= @guardian.address_line.presence || "-" %></div></div>
    </div>
  </div>
</div>

<div class="card page-card"><div class="card-body"><h2 class="section-title h5 mb-3">Linked Students</h2><% if @linked_students.any? %><% @linked_students.each do |student| %><div class="admin-related-item"><div class="font-weight-bold"><%= link_to student.full_name, student_path(student) %></div><div class="text-muted small"><%= student.student_number %></div></div><% end %><% else %><div class="text-muted">No students linked yet.</div><% end %></div></div>
