<div class="card page-card">
	<div class="card-body">
		<div class="d-flex justify-content-between align-items-center mb-4">
			<h1 class="section-title h3 mb-0"><%= @enrollment_period.name %></h1>
			<div>
				<%= link_to "Edit", edit_enrollment_period_path(@enrollment_period, return_to: params[:return_to]), class: "btn btn-outline-brand" %>
				<%= link_to "Back", safe_return_path(enrollment_periods_path), class: "btn btn-outline-secondary" %>
			</div>
		</div>

		<div class="row">
			<div class="col-md-4 mb-3"><div class="muted-label">School Year</div><div><%= @enrollment_period.school_year.name %></div></div>
			<div class="col-md-4 mb-3"><div class="muted-label">Status</div><div><%= @enrollment_period.status.titleize %></div></div>
			<div class="col-md-4 mb-3"><div class="muted-label">Dates</div><div><%= "#{@enrollment_period.starts_on.strftime('%b %d, %Y')} - #{@enrollment_period.ends_on.strftime('%b %d, %Y')}" %></div></div>
			<div class="col-md-12 mb-3"><div class="muted-label">Description</div><div><%= @enrollment_period.description.presence || "-" %></div></div>
		</div>

		<div class="row">
			<div class="col-lg-6 mb-4">
				<h2 class="section-title h5 mb-3">Classes</h2>
				<% if @academic_classes.any? %>
					<% @academic_classes.each do |academic_class| %>
						<div class="admin-related-item">
							<div class="font-weight-bold"><%= link_to academic_class.display_name, academic_class_path(academic_class) %></div>
							<div class="text-muted small"><%= academic_class.teacher&.full_name || "-" %></div>
						</div>
					<% end %>
				<% else %>
					<div class="text-muted">No classes yet.</div>
				<% end %>
			</div>

			<div class="col-lg-6 mb-4">
				<h2 class="section-title h5 mb-3">Enrollments</h2>
				<% if @enrollments.any? %>
					<% @enrollments.each do |enrollment| %>
						<div class="admin-related-item">
							<div class="font-weight-bold"><%= link_to enrollment.student.full_name, student_path(enrollment.student) %></div>
							<div class="text-muted small"><%= enrollment.academic_class.display_name %></div>
						</div>
					<% end %>
				<% else %>
					<div class="text-muted">No enrollments yet.</div>
				<% end %>
			</div>
		</div>
	</div>
</div>
