<%
  columns = [
    {
      title: "Name",
      class: "name-col font-weight-bold",
      html: ->(province) { content_tag(:span, province.name, class: "name-text") }
    },
    {
      title: "Region",
      class: "name-col",
      value: ->(province) { province.region&.name || "-" }
    },
    {
      title: "Description",
      class: "description-col",
      value: ->(province) { province.description.presence || "-" }
    },
    {
      title: "Remarks",
      class: "remarks-col",
      value: ->(province) { province.remarks.presence || "-" }
    },
    {
      title: "Actions",
      class: "actions-col text-right",
      html: lambda { |province|
        resource_grid_actions(
          province,
          view_path: province_path(province),
          edit_path: edit_province_path(province),
          delete_path: province_path(province)
        )
      }
    }
  ]
%>

<%= render "layouts/resource_index_grid",
           title: "Provinces",
           new_label: "New Province",
           new_path: new_province_path,
           collection: @provinces,
           columns: columns,
           grid_id: "provinces-grid" %>
