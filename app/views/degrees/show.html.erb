<div class="card page-card"><div class="card-body"><div class="d-flex justify-content-between align-items-center mb-4"><h1 class="section-title h3 mb-0"><%= @degree.name %></h1><div><%= link_to "Edit", edit_degree_path(@degree), class: "btn btn-outline-brand" %> <%= link_to "Back", degrees_path, class: "btn btn-outline-secondary" %></div></div><div class="row"><div class="col-md-4 mb-3"><div class="muted-label">Code</div><div><%= @degree.code.presence || "-" %></div></div><div class="col-md-8 mb-3"><div class="muted-label">Description</div><div><%= @degree.description.presence || "-" %></div></div></div><div class="row"><div class="col-lg-6 mb-4"><h2 class="section-title h5 mb-3">Fields of Study</h2><% if @field_of_studies.any? %><% @field_of_studies.each do |field| %><div class="admin-related-item"><div class="font-weight-bold"><%= link_to field.name, field_of_study_path(field) %></div><div class="text-muted small"><%= field.code.presence || "-" %></div></div><% end %><% else %><div class="text-muted">No fields yet.</div><% end %></div><div class="col-lg-6 mb-4"><h2 class="section-title h5 mb-3">Classes</h2><% if @academic_classes.any? %><% @academic_classes.each do |academic_class| %><div class="admin-related-item"><div class="font-weight-bold"><%= link_to academic_class.display_name, academic_class_path(academic_class) %></div><div class="text-muted small"><%= academic_class.school_year.name %></div></div><% end %><% else %><div class="text-muted">No classes yet.</div><% end %></div></div></div></div>
