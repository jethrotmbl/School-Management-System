<section class="resource-grid" aria-label="System resources">
  <% @resource_cards.each do |card| %>
    <%= render "resource_card", card: card %>
  <% end %>
</section>

<section class="dashboard-summary card">
  <div class="card-body">
    <div class="dashboard-summary__header">
      <h2 class="dashboard-summary__title">Quick Overview</h2>
      <p class="dashboard-summary__subtitle">Current totals across your key school records.</p>
    </div>

    <div class="dashboard-summary__grid">
      <% @summary_items.each do |item| %>
        <div class="dashboard-summary__item">
          <div class="dashboard-summary__item-head">
            <span class="dashboard-summary__icon" aria-hidden="true">
              <%= kendo_icon(item[:icon], classes: "dashboard-summary__icon-symbol") %>
            </span>
            <span class="dashboard-summary__label"><%= item[:title] %></span>
          </div>
          <div class="dashboard-summary__value"><%= item[:count] %></div>
          <div class="dashboard-summary__meta"><%= pluralize(item[:count], "record") %> total</div>
        </div>
      <% end %>
    </div>
  </div>
</section>
