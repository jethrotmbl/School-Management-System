<section class="home-hero">
  <div class="home-hero__brand">
    <div class="home-hero__logo" aria-hidden="true">
      <%= bootstrap_icon("mortarboard-fill", classes: "home-hero__logo-icon") %>
    </div>

    <div>
      <p class="home-hero__eyebrow">Academic Operations</p>
      <h1 class="home-hero__title">School Management System</h1>
      <p class="home-hero__subtitle">
        Manage core location records from a single dashboard with direct access to each index and create page.
      </p>
    </div>
  </div>
</section>

<section class="resource-grid" aria-label="System resources">
  <% @resource_cards.each do |card| %>
    <%= render "resource_card", card: card %>
  <% end %>
</section>
