<div class="card page-card"><div class="card-body"><div class="d-flex justify-content-between align-items-center mb-4"><h1 class="section-title h3 mb-0"><%= @citizenship.name %></h1><div><%= link_to "Edit", edit_citizenship_path(@citizenship), class: "btn btn-outline-brand" %> <%= link_to "Back", citizenships_path, class: "btn btn-outline-secondary" %></div></div><div class="mb-4"><div class="muted-label">Description</div><div><%= @citizenship.description.presence || "-" %></div></div><div class="row"><div class="col-md-4 mb-3"><div class="muted-label">Students</div><div><%= @citizenship.students.count %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Teachers</div><div><%= @citizenship.teachers.count %></div></div><div class="col-md-4 mb-3"><div class="muted-label">Guardians</div><div><%= @citizenship.guardians.count %></div></div></div></div></div>
